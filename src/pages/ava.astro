import PlaylistReview from "../components/Ava/PlaylistReview.astro";
import LoveIsland from "../components/Ava/LoveIsland.astro";
import MusicPlayer from "../components/Ava/MusicPlayer.astro";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
