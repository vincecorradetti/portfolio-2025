		<!-- Facebook Meta Tags -->
		<meta property="og:url" content="https://vincecorradetti.com">
		<meta property="og:type" content="website">
		<meta property="og:title" content="Vince Corradetti | UI Engineer">
		<meta property="og:description" content="I'm Vince! A super passionate engineer experienced in building marketing & e-commerce sites. I believe the web should be fun and accessible for all!">
		<meta property="og:image" content="https://vincecorradetti.com/images/gift-og.png">

		<!-- Twitter Meta Tags -->
		<meta name="twitter:card" content="summary_large_image">
		<meta property="twitter:domain" content="vincecorradetti.com">
		<meta property="twitter:url" content="https://vincecorradetti.com">
		<meta name="twitter:title" content="Vince Corradetti | UI Engineer">
		<meta name="twitter:description" content="I'm Vince! A super passionate engineer experienced in building marketing & e-commerce sites. I believe the web should be fun and accessible for all!">
		<meta name="twitter:image" content="https://vincecorradetti.com/images/gift-og.png">
    <meta name="robots" content="noindex, nofollow" />

		<link rel="icon" type="image/png" href="/favicon/favicon-96x96.png" sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
		<link rel="shortcut icon" href="/favicon/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
		<meta name="apple-mobile-web-app-title" content="Vince | UI" />
		<link rel="manifest" href="/favicon/site.webmanifest" />

		<link rel="stylesheet" href="/styles/ava.css">
		<title>Happy Birthday Ava!!</title>
	</head>
	<body>
		<main class="swiper">
      <ul class="swiper-wrapper">
        <li class="swiper-slide"><Present /></li>
        <li class="swiper-slide"><Age /></li>
        <li class="swiper-slide"><Intro /></li>
        <li class="swiper-slide"><Home /></li>
        <li class="swiper-slide"><PlaylistReview /></li>
        <li class="swiper-slide"><LoveIsland /></li>
      </ul>
      <div class="swiper-pagination"></div>
      <button class="swiper-button-prev"></div>
      <button class="swiper-button-next"></div>
		</main>

    <MusicPlayer />
	</body>
</html>

<script>
  import { gsap } from "gsap";
  import Swiper from "swiper";
  import { Navigation, Pagination, EffectFade } from "swiper/modules";

  function initCarousel() {
    const swiper = new Swiper(".swiper", {
      modules: [Navigation, Pagination, EffectFade],
      slidesPerView: 1,
      noSwiping: true,
      noSwipingClass: "swiper-slide",
      navigation: {
        prevEl: ".swiper-button-prev",
        nextEl: ".swiper-button-next",
      },
      pagination: {
        el: ".swiper-pagination",
        type: "bullets",
        clickable: true,
      },
    });

    return swiper;
  }

  function initGsapAnimations(swiper: Swiper) {
    swiper.on("slideChangeTransitionStart", () => {
      const slide = swiper.slides[swiper.activeIndex];
      const klass = getActiveSlideClass(slide);

      switch(klass) {
        case ".story--age":
          playAgeStory(slide);
          break;
        default:
          break;
      }
    });
  }

  function playAgeStory(slide: HTMLElement) {
    const hasPlayed = slide.getAttribute("data-played-animation");
    if (hasPlayed === "true") return;

    gsap.fromTo(
      slide,
      {
        clipPath: "circle(5% at 50% 50%)"
      },
      {
        clipPath: "circle(100% at 50% 50%)",
        duration: 0.75,
        ease: "power4.in"
      }
    );
    slide.setAttribute("data-played-animation", "true");
  }

  // duplicated in `MusicPlayer.astro`
  function getActiveSlideClass(slide: HTMLElement) {
    const story = slide?.querySelector(".story");
    const klasses = story ? Array.from(story.classList) : [];
    const storyClass = klasses?.find((klass) => klass.startsWith("story--"));
    return `.${storyClass}`;
  }

  const swiper = initCarousel();
  initGsapAnimations(swiper);
</script>

